{
    # Proporciona un email global para que Let's Encrypt / ZeroSSL 
    # cree automáticamente certificados de producción válidos.
    email admin@osodreamer.lat

    # Caddy exige un endpoint de permiso para generar certificados al vuelo y evitar spam.
    # Usaremos el backend para validar que el subdominio realmente existe en la BD maestra.
    on_demand_tls {
        ask http://api:3000/api/public/tenant/validate-domain
    }
}

# Unificamos todo bajo el manejador de host comodín para aplicar On-Demand TLS parejo
*.osodreamer.lat {
    # Evitamos que Caddy intente obtener un certificado Wildcard imposible (sin DNS plugin)
    # y en su lugar emita un certificado bajo demanda por cada subdominio visitado.
    tls {
        on_demand
    }

    # 1. Enrutamiento para el Backend API
    @api host api.osodreamer.lat
    handle @api {
        reverse_proxy api:3000
    }

    # 2. Enrutamiento para los Tenantes (Frontend SaaS)
    # Si no es la API, todo el resto de subdominios caen aquí
    handle {
        reverse_proxy saas_frontend_app:80
    }
}
