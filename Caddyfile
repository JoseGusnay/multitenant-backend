{
    # Proporciona un email global para que Let's Encrypt / ZeroSSL 
    # cree automáticamente certificados de producción válidos (como el Wildcard)
    email admin@osodreamer.lat
}

# Subdominio de la API de Producción (HTTPS Automático)
api.osodreamer.lat {
    # Redirige todo el tráfico web entrante hacia el contenedor de la API en el puerto 3000
    reverse_proxy api:3000
}

# Frontend del SaaS (Maneja todos los subdominios dinámicamente)
*.osodreamer.lat {
    # Al declarar un asterisco, Caddy intentará obtener un certificado TLS Wildcard.
    # En casos donde no tienes un plugin DNS, Caddy usará ZeroSSL On-Demand HTTP
    # o Let's Encrypt TLS-ALPN-01 challenge si el puerto 443 apunta al VPS.

    # El Frontend de Angular correrá en otro docker-compose exponiendo el puerto 4200 al host (VPS).
    reverse_proxy 172.17.0.1:4200
}
